{
  "info": {
    "name": "AI-Genius JWT RBAC Assignment",
    "description": "Postman collection for Login -> Protected API -> Access Denied -> Refresh Token -> Logout workflow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login as Admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json.accessToken) { pm.collectionVariables.set('accessToken', json.accessToken); }",
              "if (json.user) { pm.collectionVariables.set('role', json.user.role); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@aigenius.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "2. Login as Premium User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json.accessToken) { pm.collectionVariables.set('accessToken', json.accessToken); }",
              "if (json.user) { pm.collectionVariables.set('role', json.user.role); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"premium@aigenius.com\",\n  \"password\": \"premium123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "3. Login as Free User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json.accessToken) { pm.collectionVariables.set('accessToken', json.accessToken); }",
              "if (json.user) { pm.collectionVariables.set('role', json.user.role); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"free@aigenius.com\",\n  \"password\": \"free123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "4. Access Free Model - All Logged In Users",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ai/free-model",
          "host": ["{{baseUrl}}"],
          "path": ["ai", "free-model"]
        }
      }
    },
    {
      "name": "5. Access Premium Model - Premium/Admin Only",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prompt\": \"Generate a premium AI marketing caption.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/ai/premium-model",
          "host": ["{{baseUrl}}"],
          "path": ["ai", "premium-model"]
        }
      }
    },
    {
      "name": "6. Purge Cache - Admin Only",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
        },
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ai/purge-cache",
          "host": ["{{baseUrl}}"],
          "path": ["ai", "purge-cache"]
        }
      }
    },
    {
      "name": "7. Refresh Access Token from Cookie",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "if (json.accessToken) { pm.collectionVariables.set('accessToken', json.accessToken); }"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "refresh"]
        }
      }
    },
    {
      "name": "8. Logout - Revoke Refresh Token",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "logout"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "role",
      "value": "",
      "type": "string"
    }
  ]
}
